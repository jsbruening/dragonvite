{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.local", ".eslintrc", "prettier.config.js"],
  "globalEnv": ["TURBO_WORKSPACE"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "type-check"],
      "outputs": ["dist/**", ".next/**", "build/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "outputs": ["test-results/**"],
      "cache": false,
      "dependsOn": ["build"]
    },
    "type-check": {
      "outputs": [],
      "cache": true
    }
  }
}
